<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <!-- The component's template -->
    <t t-name="RAK.TaxToggleModeButton">
        <button t-attf-class="{{props.class}} flex-shrink-0" t-on-click="onClick">
            <i class="fa fa-percent me-1" role="img" aria-label="Tax Mode" title="Tax Mode" />
            <t t-if="pos.manual_price_tax_included">
                <span>Tax Incl.</span>
            </t>
            <t t-else="">
                <span>Tax Excl.</span>
            </t>
        </button>
    </t>

    <!-- The template extension -->
    <t t-name="RAK.ControlButtons" t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension">
        <xpath expr="//InternalNoteButton" position="after">
            <TaxToggleModeButton t-if="!props.showRemainingButtons || (ui.isSmall and props.showRemainingButtons)" t-att-class="buttonClass" />
        </xpath>
    </t>
</templates>
